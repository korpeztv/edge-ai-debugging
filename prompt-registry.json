{
  "registry_version": "1.0.0",
  "description": "Centralized registry of LLM debugging prompts with versioning and metadata",
  "prompts": [
    {
      "id": "llm-debugger-1",
      "title": "Logic & Reasoning Diagnostic",
      "version": "1.0.0",
      "file": "prompts/llm-debugger-1.md",
      "focus": "Reasoning and arithmetic state tracking",
      "category": "reasoning",
      "difficulty": "easy",
      "min_context_tokens": 500,
      "tags": [
        "state-tracking",
        "arithmetic",
        "reasoning"
