      "tags": [
        "json",
        "entity-extraction",
        "role-adherence"
      ],
      "expected_output_type": "json",
      "expected_output_schema": {
        "type": "object",
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "llm-debugger-4",
      "title": "Hallucination/Grounding Audit",
