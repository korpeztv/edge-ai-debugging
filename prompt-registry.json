      "expected_output_type": "numeric",
      "expected_output": "6"
    },
    {
      "id": "llm-debugger-2",
      "title": "Negative Constraint Debugger",
      "version": "1.0.0",
      "file": "prompts/llm-debugger-2.md",
      "focus": "Negative constraints and restricted wording",
      "category": "instruction-following",
      "difficulty": "medium",
      "min_context_tokens": 800,
      "tags": [
        "constraints",
        "negative-instructions",
        "formatting"
      ],
      "expected_output_type": "text",
      "constraints": {
        "must_not_contain": ["the"],
        "must_not_use": ["bullet-points"],
        "sentence_count": 3,
        "must_end_with": "process"
      }
    },
    {
      "id": "llm-debugger-3",
      "title": "Instruction-Following Format Stressor",
      "version": "1.0.0",
