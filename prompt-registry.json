  "difficulty_levels": {
    "easy": "Model with 7B+ parameters should reliably pass",
    "medium": "Model with 13B+ parameters recommended",
    "hard": "Model with 30B+ parameters or advanced fine-tuning recommended"
  },
  "testing_guidance": {
    "temperature": 0,
    "top_p": 1.0,
    "max_tokens": "varies by prompt",
    "retry_count": 1,
    "isolation_required": "Always separate System Prompt from User Prompt"
  },
