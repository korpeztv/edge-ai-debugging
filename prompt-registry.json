  "categories": {
    "reasoning": "Tests core logic, arithmetic, and state tracking",
    "instruction-following": "Tests adherence to constraints and formatting rules",
    "structured-output": "Tests JSON output, extraction, and role consistency",
    "safety": "Tests grounding, hallucination resistance, and reliability",
    "meta-reasoning": "Tests self-reflection and introspection capability",
    "context-handling": "Tests focus and recall under noise",
    "security": "Tests prompt injection and system isolation",
    "tool-use": "Tests function calling and parameter constraint discipline",
    "comprehension": "Tests linguistic nuance and sentiment understanding"
